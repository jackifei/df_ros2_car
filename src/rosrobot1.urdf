<?xml version="1.0"?>
<robot name="rosrobot">

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://rosrobot_description/meshes/base_link.STL" />
      </geometry>
      <material name="material">
        <color rgba="1.00000000 1.00000000 1.00000000 1.00000000"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://rosrobot_description/meshes/base_link.STL" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.0015022 0.0003197 -0.043953" rpy="0 0 0" />
      <mass value="7.8207854" />
      <inertia ixx="0.0269188" ixy="0.0000004" ixz="0.0000024" iyy="0.0938631" iyz="0" izz="0.1119846" />
    </inertial>
  </link>

  <link name="lidar_Link">
    <visual>
      <origin xyz="0.14 0 0.23" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.04" length="0.05" />
      </geometry>
      <material name="material">
        <color rgba="0.80784706 0.84314118 0.90588627 1.00000000"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://rosrobot_description/meshes/lidar_Link.STL" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.008269 0.0017596 -0.0617598" rpy="0 0 0" />
      <mass value="1.4207854" />
      <inertia ixx="0.0021721" ixy="0.0000004" ixz="0.0000024" iyy="0.0051165" iyz="0" izz="0.005318" />
    </inertial>
  </link>

  <link name="lh_Link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://rosrobot_description/meshes/lh_Link.STL" />
      </geometry>
      <material name="material">
        <color rgba="0.79216078 0.81961176 0.93333725 1.00000000"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://rosrobot_description/meshes/lh_Link.STL" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.0000036 -0.0166385 -0.00003" rpy="0 0 0" />
      <mass value="0.2766274" />
      <inertia ixx="0.0003767" ixy="0" ixz="0" iyy="0.000672" iyz="0" izz="0.0003768" />
    </inertial>
  </link>

  <link name="rh_Link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://rosrobot_description/meshes/rh_Link.STL" />
      </geometry>
      <material name="material">
        <color rgba="0.79216078 0.81961176 0.93333725 1.00000000"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://rosrobot_description/meshes/rh_Link.STL" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.0000082 0.0166385 -0.0000291" rpy="0 0 0" />
      <mass value="0.2766273" />
      <inertia ixx="0.0003767" ixy="0" ixz="0" iyy="0.000672" iyz="0" izz="0.0003768" />
    </inertial>
  </link>

  <link name="lq_Link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://rosrobot_description/meshes/lq_Link.STL" />
      </geometry>
      <material name="material">
        <color rgba="1.00000000 1.00000000 1.00000000 1.00000000"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://rosrobot_description/meshes/lq_Link.STL" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.000799 0.0428091 -0.0364805" rpy="0 0 0" />
      <mass value="0.2903047" />
      <inertia ixx="0.0003809" ixy="0.0000067" ixz="0" iyy="0.0006782" iyz="0" izz="0.0003759" />
    </inertial>
  </link>

  <link name="rq_Link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://rosrobot_description/meshes/rq_Link.STL" />
      </geometry>
      <material name="material">
        <color rgba="0.95686667 0.74510196 0.84314118 1.00000000"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://rosrobot_description/meshes/rq_Link.STL" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.0012773 -0.042979 -0.0364771" rpy="0 0 0" />
      <mass value="0.2976166" />
      <inertia ixx="0.0003817" ixy="0.0000066" ixz="0" iyy="0.0006786" iyz="0" izz="0.0003769" />
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link" />
    <child link="lidar_Link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <joint name="lh_joint" type="continuous">
    <parent link="base_link" />
    <child link="lh_Link" />
    <origin xyz="-0.1391668 0.1725 -0.14" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <limit effort="0" velocity="0" />
  </joint>

  <joint name="rh_joint" type="continuous">
    <parent link="base_link" />
    <child link="rh_Link" />
    <origin xyz="-0.1391668 -0.1725 -0.14" rpy="0 0 0" />
    <axis xyz="0 -1 0" />
    <limit effort="0" velocity="0" />
  </joint>

  <joint name="lq_joint" type="revolute">
    <parent link="base_link" />
    <child link="lq_Link" />
    <origin xyz="0.1670723 0.16 -0.0985" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-0.7" upper="0.7" effort="0" velocity="0" />
  </joint>

  <joint name="rq_joint" type="revolute">
    <parent link="base_link" />
    <child link="rq_Link" />
    <origin xyz="0.1670723 -0.16 -0.0985" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-0.7" upper="0.7" effort="0" velocity="0" />
  </joint>

  <!-- ================================================================ -->
  <!-- ros2_control 硬件接口 — 同步后驱方案 (Gazebo Harmonic)              -->
  <!--                                                                -->
  <!-- gz_ros2_control/GazeboSimSystem: Gazebo Harmonic 的硬件插件      -->
  <!--   - 后轮 (lh_joint, rh_joint): velocity 指令接口                  -->
  <!--   - 前轮 (lq_joint, rq_joint): position 指令接口                  -->
  <!-- ================================================================ -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <!-- ★ Gazebo Harmonic 使用 gz_ros2_control（非 gazebo_ros2_control）-->
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <!-- 左后轮：连续转动，velocity 控制 -->
    <joint name="lh_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>

    <!-- 右后轮：连续转动，velocity 控制 -->
    <joint name="rh_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>

    <!-- 左前轮转向：revolute，position 控制（±0.7 rad 限位） -->
    <joint name="lq_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- 右前轮转向：revolute，position 控制（±0.7 rad 限位） -->
    <joint name="rq_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ================================================================ -->
  <!-- gz_ros2_control 系统插件 (Gazebo Harmonic 必需)                    -->
  <!--                                                                -->
  <!--   加载 GazeboSimROS2ControlPlugin，                              -->
  <!--   桥接 Gazebo update 循环与 ros2_control controller_manager      -->
  <!--   插件文件: libgz_ros2_control-system.so                          -->
  <!--   参数指向 ros2_control.yaml 控制器配置文件                        -->
  <!-- ================================================================ -->
  <gazebo>
    <plugin
        name="gz_ros2_control::GazeboSimROS2ControlPlugin"
        filename="libgz_ros2_control-system.so">
      <parameters>$(find rosrobot_description)/config/ros2_control.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- ================================================================ -->
  <!-- Gazebo Harmonic LiDAR 激光雷达传感器                              -->
  <!--                                                                -->
  <!-- Gazebo Harmonic 不再使用 libgazebo_ros_ray_sensor.so 桥接插件       -->
  <!--   传感器数据发布到 Gazebo 内部 topic: /lidar                       -->
  <!--   由 ros_gz_bridge 桥接到 ROS /scan (LaserScan)                    -->
  <!--                                                                -->
  <!--   传感器安装在 lidar_Link 上，360° 扫描，15 Hz 更新率               -->
  <!-- ================================================================ -->
  <gazebo reference="lidar_Link">
    <sensor name="lidar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <topic>lidar</topic>
      <update_rate>15</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.02</resolution>
        </range>
      </ray>
      <always_on>1</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- ================================================================ -->
  <!-- Gazebo 物理材质 — 后轮摩擦系数（驱动轮需要足够抓地力）              -->
  <!-- ================================================================ -->
  <gazebo reference="lh_Link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="rh_Link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

</robot>